# ==============================================================================
# RAG PIPELINE CENTRALIZED ENVIRONMENT CONFIGURATION
# ==============================================================================

# --- LLM & External Parsing APIs ---
GEMINI_API_KEY=your_gemini_api_key_here
LLAMAPARSE_API_KEY=your_llamaparse_api_key_here

# --- AWS Storage Infrastructure (S3) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_legal_raw_pdfs_bucket

# --- Vector Database Configurations ---
LANCE_DB_PATH=/app/data/.lancedb

# --- Local Service Execution Modes ---
# Options: development, production
ENVIRONMENT=development